# MODEL_PROVIDER=mock
# NVIDIA NIM settings
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_API_KEY=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
# NVIDIA_MODEL=microsoft/phi-4-mini-instruct
# NVIDIA_MODEL_FALLBACKS=microsoft/phi-4-mini-instruct,minimaxai/minimax-m3

# Hugging Face settings
# HUGGINGFACE_API_KEY=your-key-here
# HUGGINGFACE_MODEL=nvidia_nim/minimaxai/minimax-m3

# Anthropic settings
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Use fallback mock result when the real provider fails
# MOCK_FALLBACK=true

# --- Supabase (stores generated access codes) ---
# Project Settings > API in your Supabase dashboard.
# Use the service_role key here, never the anon key. This file never
# reaches the browser, but double check it's not committed to git.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Paystack ---
# Use a test secret key (sk_test_...) until you're ready to go live,
# then swap to the live key (sk_live_...).
PAYSTACK_SECRET_KEY=sk_test_your-key

# Price per resume check, in naira (whole number, no commas).
PRICE_NGN=1500

# Your live frontend URL. Paystack redirects here after payment, and it
# doubles as the callback the frontend reads ?reference= from.
# Local dev default matches `npm run dev` in the frontend folder.
APP_URL=http://localhost:5173
