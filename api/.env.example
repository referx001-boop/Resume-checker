# MODEL_PROVIDER=mock
# NVIDIA NIM settings
# NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
# NVIDIA_API_KEY=your-nvidia-key
# NVIDIA_MODEL=microsoft/phi-4-mini-instruct
# NVIDIA_MODEL_FALLBACKS=microsoft/phi-4-mini-instruct,minimaxai/minimax-m3

# Hugging Face settings
# HUGGINGFACE_API_KEY=your-key-here
# HUGGINGFACE_MODEL=nvidia_nim/minimaxai/minimax-m3

# Anthropic settings
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Use fallback mock result when the real provider fails
# MOCK_FALLBACK=true
